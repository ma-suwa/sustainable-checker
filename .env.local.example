# Claude API key (required). Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model used for rubric evaluation. Default is cost/speed friendly.
# High-accuracy alternative: claude-opus-4-8
DIAGNOSE_MODEL=claude-sonnet-5

# Max number of sustainability sub-pages to crawl per diagnosis (bounds cost/latency).
CRAWL_MAX_PAGES=10

# Per-page navigation timeout in milliseconds.
CRAWL_TIMEOUT_MS=20000
